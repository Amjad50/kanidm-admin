# Caddyfile for the docker-compose stack.
#
# Two backends:
#   - admin-ui (this project, plain HTTP on :3000 inside the network)
#   - kanidm   (kanidm/server image, HTTPS on :8443 with self-signed cert)
#
# Caddy terminates TLS on :443 using its internal CA (one-time
# user-trust step covered by SETUP.md). The hostname `idm.localhost`
# is RFC 6761; modern browsers resolve it to 127.0.0.1 automatically.
#
# Routing is now path-prefix based on a single rule: anything under
# /admin/* goes to admin-ui; the bare root / falls through to kanidm
# too, but admin-ui itself returns a 308 redirect to /admin if hit at
# root (so admin.idm.localhost-style subdomain deployments also land
# users on the right page without any extra config).

idm.localhost {
	tls internal

	# Admin UI owns the /admin/* tree (everything: login, /me, healthz,
	# static assets — see src/handlers/mod.rs).
	handle /admin* {
		reverse_proxy admin-ui:3000 {
			header_up Host {host}
		}
	}

	# Everything else (/, /v1/*, /scim/*, /oauth2/*, /.well-known/*,
	# /ui/*, etc.) falls through to kanidm. Kanidm's TLS cert is
	# self-signed; tls_insecure_skip_verify is fine because the
	# connection stays inside the docker network.
	handle {
		reverse_proxy https://kanidm:8443 {
			transport http {
				tls
				tls_insecure_skip_verify
			}
			header_up Host {host}
		}
	}
}
