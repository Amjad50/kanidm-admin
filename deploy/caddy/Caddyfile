# Caddyfile for the docker-compose stack.
#
# Two backends:
#   - admin-ui (this project, plain HTTP on :3000 inside the network)
#   - kanidm   (kanidm/server image, HTTPS on :8443 with self-signed cert)
#
# Caddy terminates TLS on :443 using its internal CA (one-time
# user-trust step covered by SETUP.md). The hostname `idm.localhost`
# is RFC 6761; modern browsers resolve it to 127.0.0.1 automatically.
#
# Master serves only admin pages + login + /me + utility endpoints —
# kanidm handles everything else via the catch-all. When user-facing
# pages (apps, profile, sessions, etc.) are ported into admin-ui, add
# their paths to @ui_paths.

idm.localhost {
	tls internal

	# ── All admin-UI traffic ──────────────────────────────────────────────
	# Admin-only routes live under /admin/*. Login, /me, and utility
	# endpoints stay at root.
	@ui_paths {
		path /admin /admin/*
		path /login /login/*
		path /logout
		path /me /me/*
		path /healthz
		path /empty
		path /static/*
	}
	handle @ui_paths {
		reverse_proxy admin-ui:3000 {
			header_up Host {host}
		}
	}

	# ── Kanidm: catch-all ─────────────────────────────────────────────────
	# Root /, /v1/*, /scim/*, /oauth2/*, /.well-known/*, /ui/*, etc.
	# Kanidm's TLS cert is self-signed (generated by the kanidm-init service).
	# tls_insecure_skip_verify is acceptable here because the connection is
	# purely internal to the docker network.
	handle {
		reverse_proxy https://kanidm:8443 {
			transport http {
				tls
				tls_insecure_skip_verify
			}
			header_up Host {host}
		}
	}
}
